{
  "name": "antigravity-skills-generator",
  "displayName": "Antigravity-S2W",
  "description": "Transform installed AI skills into executable Antigravity Workflows",
  "publisher": "KerrYang56",
  "icon": "resources/antigravity-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/KerrYang56/Antigravity-S2W.git"
  },
  "version": "0.0.6",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "antigravity-skills-container",
          "title": "Antigravity-S2W",
          "icon": "resources/antigravity-icon.svg"
        }
      ]
    },
    "views": {
      "antigravity-skills-container": [
        {
          "id": "antigravityInstructions",
          "name": "Skills Manager",
          "icon": "resources/antigravity-icon.svg",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "antigravity.refresh",
        "title": "Refresh Skills",
        "icon": "$(refresh)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.2.5",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "@vscode/test-electron": "^2.3.2",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.1.3",
    "webpack": "^5.85.0",
    "webpack-cli": "^5.1.1"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  }
}
